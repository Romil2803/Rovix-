rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper rules
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'ssanganiromil@gmail.com';
    }

    // User Profile Rules
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || (isAuthenticated() && request.resource.data.id == userId) || isAdmin();
    }

    // Reviews Rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isAdmin();
      allow update: if (isAuthenticated() && (resource.data.userId == request.auth.uid || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'likedBy', 'replies', 'isReported']))) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Ratings Rules
    match /ratings/{ratingId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Watchlist Rules
    match /watchlist/{watchlistId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Custom Watchlist Rules
    match /custom_watchlists/{watchlistId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Follows Rules
    match /follows/{followId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Notifications Rules
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAuthenticated();
    }

    // Announcements Rules
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Reports Rules
    match /reports/{reportId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Community Posts Rules
    match /community_posts/{postId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Collections Rules
    match /collections/{collectionId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Fanzone Threads Rules
    match /fanzone_threads/{threadId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Fanzone Theories Rules
    match /fanzone_theories/{theoryId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Fanzone Polls Rules
    match /fanzone_polls/{pollId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    // Fanzone Quotes Rules
    match /fanzone_quotes/{quoteId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }
  }
}
